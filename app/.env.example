### trading agent environment variables
TAVILY_API_KEY=your_tavily_api_key_here

# Set one or both — engine auto-selects Anthropic first, falls back to Gemini
ANTHROPIC_API_KEY=your_anthropic_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here


### telegram bot environment variables
# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Local sqlite database + per-user Circle CLI session storage
DATABASE_URL=./data/bot.sqlite
SESSION_DIR=./data/sessions

# PUA agent (Python) bridge
# PUA_REPO_ROOT must point at the PUAAgents repo root (contains orchestrator/).
# Defaults to the parent directory of app/.
PUA_REPO_ROOT=..
# Python interpreter used to run the pipeline. Point this at the repo venv,
# e.g. ../.venv/bin/python, so the PUA dependencies are available.
PYTHON_BIN=python3

# Circle Gateway API (testnet)
GATEWAY_API=https://gateway-api-testnet.circle.com

# Demo bankroll in USDC. A trade's notional = decision.size * TRADE_BANKROLL.
TRADE_BANKROLL=10

LOG_LEVEL=info
