TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Optional override of the periodic-scan interval (seconds). Default: 3600.
# SCAN_INTERVAL_S=3600

# The following are also read from the project root .env if present; you only
# need to set them here if you want the bot to use different keys than the
# rest of the pipeline.
# TAVILY_API_KEY=
# ANTHROPIC_API_KEY=
# GEMINI_API_KEY=
